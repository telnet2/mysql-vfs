# Database Configuration
DB_DSN=root:root@tcp(mysql:3306)/vfs?charset=utf8mb4&parseTime=True&loc=Local

# S3/Object Storage Configuration
S3_ENDPOINT=http://localstack:4566
S3_BUCKET=cc-vfs-storage
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1

# Service Configuration
PORT=8080
LOG_LEVEL=debug

# Idempotency Configuration
# TTL for idempotency records in seconds (default: 86400 = 24 hours)
IDEMPOTENCY_TTL_SECONDS=86400

# Webhook Configuration
WEBHOOK_DAEMON_URL=http://webhook-daemon:9000

# Worker Configuration
WORKER_CONCURRENCY=10
POLL_INTERVAL=1s

# Scheduler Configuration
SCHEDULER_ID=scheduler-1

# Auth Configuration (stubbed for Phase 1)
JWT_SECRET=change-me-in-production
